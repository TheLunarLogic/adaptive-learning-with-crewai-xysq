# xysq — persistent memory layer
XYSQ_API_KEY=xysq_your_key_here

# ── AI Provider ────────────────────────────────────────────────────────────
# Set PROVIDER to one of: "Google Gemini", "OpenAI", "AWS Bedrock"
PROVIDER=Google Gemini

# Google Gemini
MODEL=gemini/gemini-2.0-flash
API_KEY=your_gemini_api_key

# OpenAI (uncomment if using OpenAI)
# MODEL=gpt-4o
# API_KEY=your_openai_api_key

# AWS Bedrock (uncomment if using Bedrock)
# MODEL=bedrock/us.amazon.nova-lite-v1:0
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_DEFAULT_REGION=us-east-1

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (set on Railway in production)
# e.g. ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=
